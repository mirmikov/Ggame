# For production, set this to your public domain, for example:
# SITE_ADDRESS=game.example.com
#
# Caddy will listen on 80/443 and proxy the app internally.
# The frontend, API, and WebSocket endpoints will all be available on the same domain.
# Plain HTTP on port 80 also remains available as an IP/fallback check while DNS propagates.
SITE_ADDRESS=localhost
HTTP_PORT=80
HTTPS_PORT=443

# PostgreSQL settings used by compose.yaml.
POSTGRES_DB=ggame
POSTGRES_USER=ggame
POSTGRES_PASSWORD=change-me-please
